{
  "manifest_version": 3,
  "name": "Echo-Todo",
  "version": "0.1.0",
  "description": "しゃべるだけでタスクを記録する、ゆるくて楽しいTodoアプリ",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
